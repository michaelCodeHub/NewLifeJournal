{
  "expo": {
    "name": "NewLifeJournal",
    "slug": "newlifejournal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "newlifejournal",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.newlifejournal.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.821548594099-9eghjqilb53r57n0e95iurlj31v4n47b"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.newlifejournal.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "@react-native-google-signin/google-signin",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow NewLifeJournal to access your photos to share with AI assistant.",
          "cameraPermission": "Allow NewLifeJournal to use the camera to take photos for AI assistant."
        }
      ],
      "expo-document-picker"
    ],
    "extra": {
      "aiProvider": "anthropic",
      "anthropicModel": "claude-3-5-sonnet-20241022",
      "openaiModel": "gpt-4o",
      "geminiModel": "gemini-1.5-pro",
      "router": {},
      "eas": {
        "projectId": "40995e87-5d67-42d7-ab62-c01cc7227cca"
      }
    }
  }
}
